package EXP_2;
import java.util.*;
public class Q_5 {
	public static void main(String[] args) {
		PriorityQueue<Integer> pq= new PriorityQueue<Integer>();
		int[] arr= {1,2,3,4,5,6};
		for(int ele:arr){
			pq.add(ele);
		}
		System.out.println("Printing Priority Queue Heap:"+pq);
		System.out.println("Q:"+pq);
	}
}
