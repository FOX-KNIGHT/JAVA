package AAD1_EXP2;

import java.util.Scanner;

public class Sum_of_n_num {
	public static int sum_of(int num, int sum) {
		if (num == 0) {
			return sum;
		} else {
			sum += num;
			return sum_of(num - 1, sum);
		}

	}

	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.print("Enter num:");
		int num = sc.nextInt();
		int sum = 0;
		System.out.println(sum_of(num, sum));
		sc.close();
	}
}
